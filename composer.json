{
    "name": "andydefer/algo-kit",
    "description": "Algo KIT - Probabilistic data structures and algorithms for large-scale data processing in PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "andydefer/storage-kit": "^0.7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "symfony/var-dumper": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\AlgoKIT\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\AlgoKIT\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
